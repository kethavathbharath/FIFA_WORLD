{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-console": "off",
    "strict": ["error", "function"],
    "eqeqeq": "error",
    "curly": "off",
    "no-eval": "error",
    "no-implied-eval": "error"
  }
}
